---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Anteckningsbiblioteket",
  description = "Ett sökbart anteckningsbibliotek med artiklar i Markdown och MDX.",
} = Astro.props;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Huvudnavigation">
        <a class="brand" href="/">Anteckningsbiblioteket</a>
        <div class="nav-links">
          <a href="/">Alla artiklar</a>
          <a href="/admin/" data-admin-link>Admin</a>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
