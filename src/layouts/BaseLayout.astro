---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kunskapsbank",
  description = "En personlig kunskapsbank med idéer, anteckningar och inspiration.",
} = Astro.props;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Huvudnavigation">
        <a class="brand" href="/">Kunskapsbank</a>
        <a href="/">Alla poster</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
