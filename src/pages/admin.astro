<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin | Anteckningsbiblioteket</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f8f7f3;
        --surface: #ffffff;
        --text: #20211f;
        --muted: #656960;
        --line: #dedbd2;
        --accent: #1b6b5d;
        --danger: #a73535;
      }

      * {
        box-sizing: border-box;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        line-height: 1.5;
        margin: 0;
      }

      main {
        margin: 0 auto;
        max-width: 860px;
        padding: 42px 18px 72px;
      }

      a {
        color: var(--accent);
        font-weight: 700;
        text-decoration: none;
      }

      h1 {
        font-size: clamp(2rem, 7vw, 3.4rem);
        letter-spacing: 0;
        line-height: 1.1;
        margin: 16px 0 10px;
      }

      p {
        color: var(--muted);
        margin: 0 0 24px;
      }

      form {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
        display: grid;
        gap: 16px;
        padding: 18px;
      }

      .admin-panel {
        display: grid;
        gap: 16px;
      }

      label {
        display: grid;
        font-weight: 750;
        gap: 7px;
      }

      input,
      textarea {
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--text);
        font: inherit;
        padding: 12px 13px;
        width: 100%;
      }

      textarea {
        min-height: 420px;
        resize: vertical;
      }

      input:focus,
      textarea:focus {
        border-color: var(--accent);
        outline: 3px solid rgba(27, 107, 93, 0.16);
      }

      button {
        background: var(--accent);
        border: 0;
        border-radius: 8px;
        color: #ffffff;
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        min-height: 46px;
        padding: 12px 16px;
      }

      button:disabled {
        cursor: wait;
        opacity: 0.7;
      }

      .top-row {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: space-between;
      }

      .secondary-button {
        background: transparent;
        border: 1px solid var(--line);
        color: var(--text);
      }

      [hidden] {
        display: none !important;
      }

      .hint {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 500;
      }

      .status {
        border-radius: 8px;
        display: none;
        margin-top: 16px;
        padding: 14px;
      }

      .status.is-visible {
        display: block;
      }

      .status.success {
        background: #e8f5ef;
        color: #145143;
      }

      .status.error {
        background: #f7e8e8;
        color: var(--danger);
      }

      .warning {
        background: #fff7df;
        border: 1px solid #ead99d;
        border-radius: 8px;
        color: #6d560f;
        margin-bottom: 18px;
        padding: 12px 14px;
      }
    </style>
  </head>
  <body>
    <main>
      <a href="/">Tillbaka till webbplatsen</a>
      <h1>Publicera Markdown</h1>
      <p>
        Klistra in en färdig artikel. Slug, datum och frontmatter skapas
        automatiskt när det behövs.
      </p>

      <form data-login-form>
        <label>
          Adminlösenord
          <input
            name="password"
            type="password"
            autocomplete="current-password"
            required
          />
        </label>

        <button type="submit">Logga in</button>
      </form>

      <section class="admin-panel" data-admin-panel hidden>
        <div class="top-row">
          <strong>Inloggad</strong>
          <button class="secondary-button" type="button" data-logout>
            Logga ut
          </button>
        </div>

        <form data-admin-form>
        <label>
          Titel
          <input name="title" type="text" placeholder="Hur fungerar RAG?" required />
          <span class="hint">Slug skapas automatiskt från titeln.</span>
        </label>

        <label>
          Markdown
          <textarea
            name="markdown"
            placeholder="Skriv eller klistra in artikeln här. Frontmatter är frivilligt."
            required></textarea>
        </label>

        <button type="submit">Publicera</button>
        </form>
      </section>

      <div class="status" data-status role="status" aria-live="polite"></div>
    </main>

    <script>
      const loginForm = document.querySelector("[data-login-form]");
      const form = document.querySelector("[data-admin-form]");
      const adminPanel = document.querySelector("[data-admin-panel]");
      const status = document.querySelector("[data-status]");
      const button = form.querySelector("button");
      const loginButton = loginForm.querySelector("button");
      const logoutButton = document.querySelector("[data-logout]");

      function setLoggedIn(isLoggedIn) {
        loginForm.hidden = isLoggedIn;
        adminPanel.hidden = !isLoggedIn;
      }

      function showStatus(type, message) {
        status.className = `status is-visible ${type}`;
        status.textContent = "";

        if (typeof message === "string") {
          status.textContent = message;
          return;
        }

        status.append(message);
      }

      async function requestJson(url, options = {}) {
        let response;

        try {
          response = await fetch(url, options);
        } catch (error) {
          throw new Error(
            `Kunde inte nå ${url}. Kontrollera att Vercel Function finns och är deployad.`,
          );
        }

        const contentType = response.headers.get("content-type") ?? "";
        const bodyText = await response.text();
        let data = {};

        if (bodyText && contentType.includes("application/json")) {
          try {
            data = JSON.parse(bodyText);
          } catch {
            throw new Error(`${url} gav ogiltig JSON med status ${response.status}.`);
          }
        } else if (bodyText) {
          data = { error: bodyText.slice(0, 240) };
        }

        if (!response.ok) {
          const fallback = `${url} svarade med ${response.status} ${response.statusText}.`;
          const detail = data.error ? `${fallback} ${data.error}` : fallback;
          throw new Error(detail);
        }

        return data;
      }

      async function refreshSession() {
        try {
          const result = await requestJson("/api/session");
          setLoggedIn(Boolean(result.authenticated));
        } catch (error) {
          console.error(error);
          setLoggedIn(false);
        }
      }

      loginForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        loginButton.disabled = true;
        showStatus("success", "Loggar in...");

        const data = new FormData(loginForm);

        try {
          await requestJson("/api/login", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ password: data.get("password") }),
          });

          loginForm.reset();
          setLoggedIn(true);
          showStatus("success", "Inloggad.");
        } catch (error) {
          console.error(error);
          showStatus("error", error.message);
        } finally {
          loginButton.disabled = false;
        }
      });

      logoutButton.addEventListener("click", async () => {
        logoutButton.disabled = true;

        try {
          await requestJson("/api/logout", { method: "POST" });
          form.reset();
          setLoggedIn(false);
          showStatus("success", "Du är utloggad.");
        } catch (error) {
          console.error(error);
          showStatus("error", error.message);
        } finally {
          logoutButton.disabled = false;
        }
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        button.disabled = true;
        showStatus("success", "Publicerar...");

        const data = new FormData(form);
        const payload = {
          title: data.get("title"),
          markdown: data.get("markdown"),
        };

        try {
          const result = await requestJson("/api/publish", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          form.reset();
          const wrapper = document.createElement("div");
          const text = document.createElement("p");
          const articleLink = document.createElement("a");
          const homeLink = document.createElement("a");

          text.textContent = "Artikeln publicerades. Vercel bygger om automatiskt.";
          articleLink.href = result.articleUrl;
          articleLink.textContent = "Öppna artikeln";
          homeLink.href = "/";
          homeLink.textContent = "Gå till startsidan";
          wrapper.append(text, articleLink, " · ", homeLink);

          showStatus("success", wrapper);
        } catch (error) {
          console.error(error);
          if (String(error.message).includes("401")) setLoggedIn(false);
          showStatus("error", error.message);
        } finally {
          button.disabled = false;
        }
      });

      refreshSession();
    </script>
  </body>
</html>
