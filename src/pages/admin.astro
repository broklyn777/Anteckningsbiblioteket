---
import {
  getArticlePath,
  getArticleTitle,
  getSortedArticles,
} from "../lib/posts";

const deletableArticles = (await getSortedArticles())
  .filter((article) => article.id.startsWith("posts/"))
  .map((article) => {
    const path = getArticlePath(article.id);
    const filename = article.id.replace(/^posts\//, "");

    return {
      githubPath: `src/content/posts/${filename}`,
      title: getArticleTitle(article),
      url: `/${path}/`,
    };
  });
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin | Anteckningsbiblioteket</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f8f7f3;
        --surface: #ffffff;
        --text: #20211f;
        --muted: #656960;
        --line: #dedbd2;
        --accent: #1b6b5d;
        --danger: #a73535;
        --code-bg: #f1eee6;
      }

      * {
        box-sizing: border-box;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        line-height: 1.5;
        margin: 0;
      }

      main {
        margin: 0 auto;
        max-width: 860px;
        padding: 42px 18px 72px;
      }

      a {
        color: var(--accent);
        font-weight: 700;
        text-decoration: none;
      }

      h1 {
        font-size: clamp(2rem, 7vw, 3.4rem);
        letter-spacing: 0;
        line-height: 1.1;
        margin: 16px 0 10px;
      }

      p {
        color: var(--muted);
        margin: 0 0 24px;
      }

      form {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
        display: grid;
        gap: 16px;
        padding: 18px;
      }

      .delete-panel {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
        display: grid;
        gap: 14px;
        margin-top: 28px;
        padding: 18px;
      }

      .admin-panel {
        display: grid;
        gap: 16px;
      }

      label {
        display: grid;
        font-weight: 750;
        gap: 7px;
      }

      input,
      select,
      textarea {
        border: 1px solid var(--line);
        border-radius: 8px;
        color: var(--text);
        font: inherit;
        padding: 12px 13px;
        width: 100%;
      }

      textarea {
        min-height: 420px;
        resize: vertical;
      }

      input:focus,
      select:focus,
      textarea:focus {
        border-color: var(--accent);
        outline: 3px solid rgba(27, 107, 93, 0.16);
      }

      button {
        background: var(--accent);
        border: 0;
        border-radius: 8px;
        color: #ffffff;
        cursor: pointer;
        font: inherit;
        font-weight: 800;
        min-height: 46px;
        padding: 12px 16px;
      }

      button:disabled {
        cursor: wait;
        opacity: 0.7;
      }

      .top-row {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        justify-content: space-between;
      }

      .secondary-button {
        background: transparent;
        border: 1px solid var(--line);
        color: var(--text);
      }

      .danger-button {
        background: var(--danger);
      }

      [hidden] {
        display: none !important;
      }

      .hint {
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 500;
      }

      .status {
        border-radius: 8px;
        display: none;
        margin-top: 16px;
        padding: 14px;
      }

      .status.is-visible {
        display: block;
      }

      .status.success {
        background: #e8f5ef;
        color: #145143;
      }

      .status.error {
        background: #f7e8e8;
        color: var(--danger);
      }

      .warning {
        background: #fff7df;
        border: 1px solid #ead99d;
        border-radius: 8px;
        color: #6d560f;
        margin-bottom: 18px;
        padding: 12px 14px;
      }

      details {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 8px;
        margin-bottom: 18px;
        padding: 14px 18px;
      }

      summary {
        cursor: pointer;
        font-weight: 800;
      }

      pre {
        background: var(--code-bg);
        border-radius: 8px;
        overflow-x: auto;
        padding: 14px;
        white-space: pre-wrap;
      }

      code {
        font-family:
          ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
          "Liberation Mono", monospace;
        font-size: 0.92rem;
      }
    </style>
  </head>
  <body>
    <main>
      <a href="/">Tillbaka till webbplatsen</a>
      <h1>Publicera Markdown</h1>
      <p>
        Klistra in en färdig artikel. Slug, datum och frontmatter skapas
        automatiskt när det behövs.
      </p>

      <details open>
        <summary>Rekommenderat format för taggar och beskrivning</summary>
        <p>
          Klistra helst in hela artikeln med YAML-frontmatter överst. Då sparas
          titel, beskrivning och taggar korrekt. Börja direkt med <code>---</code>,
          utan yttre <code>```md</code>.
        </p>
        <pre><code>---
title: "Hur fungerar RAG?"
description: "Kort sammanfattning som visas på artikelkortet."
date: "2026-06-27"
tags:
  - AI
  - RAG
  - kunskap
---

Ingress eller första stycke här.

## Rubrik

Brödtext här.</code></pre>
      </details>

      <form data-admin-form>
        <label>
          Adminlösenord
          <input
            name="password"
            type="password"
            autocomplete="current-password"
            required
          />
        </label>

        <label>
          Titel
          <input name="title" type="text" placeholder="Hur fungerar RAG?" required />
          <span class="hint">Slug skapas automatiskt från titeln.</span>
        </label>

        <label>
          Markdown
          <textarea
            name="markdown"
            maxlength="750000"
            placeholder={`---\ntitle: \"Hur fungerar RAG?\"\ndescription: \"Kort sammanfattning som visas på artikelkortet.\"\ndate: \"2026-06-27\"\ntags:\n  - AI\n  - RAG\n---\n\nSkriv artikeln här.`}
            required></textarea>
          <span class="hint">
            Frontmatter är frivilligt, men behövs om du vill styra taggar och beskrivning.
          </span>
        </label>

        <button type="submit">Publicera</button>

        <button class="secondary-button" type="button" data-clear-password hidden>
          Glöm sparat lösenord
        </button>
      </form>

      <section class="delete-panel" aria-labelledby="delete-title">
        <div>
          <h2 id="delete-title">Radera artikel</h2>
          <p>
            Tar bort Markdown-filen från GitHub. Vercel bygger om automatiskt efteråt.
          </p>
        </div>

        {
          deletableArticles.length > 0 ? (
            <>
              <label>
                Artikel
                <select data-delete-path>
                  {deletableArticles.map((article) => (
                    <option value={article.githubPath} data-url={article.url}>
                      {article.title}
                    </option>
                  ))}
                </select>
              </label>

              <button class="danger-button" type="button" data-delete-button>
                Radera vald artikel
              </button>
              <span class="hint">
                Du får en bekräftelse innan filen tas bort.
              </span>
            </>
          ) : (
            <p>Det finns inga raderbara artiklar i src/content/posts/.</p>
          )
        }
      </section>

      <div class="status" data-status role="status" aria-live="polite"></div>
    </main>

    <script>
      const passwordStorageKey = "anteckningsbiblioteket_admin_password";
      const form = document.querySelector("[data-admin-form]");
      const status = document.querySelector("[data-status]");
      const publishButton = form.querySelector('button[type="submit"]');
      const clearPasswordButton = document.querySelector("[data-clear-password]");
      const passwordInput = form.querySelector('input[name="password"]');
      const deleteButton = document.querySelector("[data-delete-button]");
      const deletePathInput = document.querySelector("[data-delete-path]");

      function showStatus(type, message) {
        status.className = `status is-visible ${type}`;
        status.textContent = "";

        if (typeof message === "string") {
          status.textContent = message;
          return;
        }

        status.append(message);
      }

      async function requestJson(url, options = {}) {
        let response;

        try {
          response = await fetch(url, options);
        } catch (error) {
          throw new Error(
            `Kunde inte nå ${url}. Kontrollera att Vercel Function finns och är deployad.`,
          );
        }

        const contentType = response.headers.get("content-type") ?? "";
        const bodyText = await response.text();
        let data = {};

        if (bodyText && contentType.includes("application/json")) {
          try {
            data = JSON.parse(bodyText);
          } catch {
            throw new Error(`${url} gav ogiltig JSON med status ${response.status}.`);
          }
        } else if (bodyText) {
          data = { error: bodyText.slice(0, 240) };
        }

        if (!response.ok) {
          const fallback = `${url} svarade med ${response.status} ${response.statusText}.`;
          const detail = data.error ? `${fallback} ${data.error}` : fallback;
          throw new Error(detail);
        }

        return data;
      }

      function loadSavedPassword() {
        const savedPassword = localStorage.getItem(passwordStorageKey);
        if (!savedPassword) return;

        passwordInput.value = savedPassword;
        clearPasswordButton.hidden = false;
      }

      clearPasswordButton.addEventListener("click", () => {
        localStorage.removeItem(passwordStorageKey);
        passwordInput.value = "";
        clearPasswordButton.hidden = true;
        showStatus("success", "Sparat lösenord rensades.");
      });

      deleteButton?.addEventListener("click", async () => {
        const path = deletePathInput?.value ?? "";
        const selectedOption = deletePathInput?.selectedOptions?.[0];
        const title = selectedOption?.textContent?.trim() ?? "vald artikel";
        const password = passwordInput.value;

        if (!password) {
          showStatus("error", "Skriv adminlösenordet först.");
          passwordInput.focus();
          return;
        }

        const confirmed = window.confirm(
          `Radera "${title}"? Detta tar bort Markdown-filen från GitHub.`,
        );

        if (!confirmed) return;

        deleteButton.disabled = true;
        showStatus("success", "Raderar artikel...");

        try {
          await requestJson("/api/delete", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ password, path }),
          });

          localStorage.setItem(passwordStorageKey, password);
          selectedOption?.remove();

          if (deletePathInput && deletePathInput.options.length === 0) {
            deletePathInput.disabled = true;
            deleteButton.hidden = true;
          }

          const wrapper = document.createElement("div");
          const text = document.createElement("p");
          const homeLink = document.createElement("a");

          text.textContent = "Artikeln raderades. Vercel bygger om automatiskt.";
          homeLink.href = "/";
          homeLink.textContent = "Gå till startsidan";
          wrapper.append(text, homeLink);

          showStatus("success", wrapper);
        } catch (error) {
          console.error(error);
          showStatus("error", error.message);
        } finally {
          deleteButton.disabled = false;
        }
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        publishButton.disabled = true;
        showStatus("success", "Publicerar...");

        const data = new FormData(form);
        const payload = {
          password: data.get("password"),
          title: data.get("title"),
          markdown: data.get("markdown"),
        };

        if (String(payload.markdown ?? "").length > 750000) {
          showStatus(
            "error",
            "Artikeln är för stor för enkel admin-import. Dela upp den eller publicera via Git.",
          );
          publishButton.disabled = false;
          return;
        }

        try {
          const result = await requestJson("/api/publish", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          localStorage.setItem(passwordStorageKey, String(payload.password ?? ""));
          clearPasswordButton.hidden = false;
          form.reset();
          loadSavedPassword();

          const wrapper = document.createElement("div");
          const text = document.createElement("p");
          const articleLink = document.createElement("a");
          const homeLink = document.createElement("a");

          text.textContent = "Artikeln publicerades. Vercel bygger om automatiskt.";
          articleLink.href = result.articleUrl;
          articleLink.textContent = "Öppna artikeln";
          homeLink.href = "/";
          homeLink.textContent = "Gå till startsidan";
          wrapper.append(text, articleLink, " · ", homeLink);

          showStatus("success", wrapper);
        } catch (error) {
          console.error(error);
          showStatus("error", error.message);
        } finally {
          publishButton.disabled = false;
        }
      });

      loadSavedPassword();
    </script>
  </body>
</html>
