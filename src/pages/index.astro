---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatDate,
  getArticleCategory,
  getArticleDescription,
  getArticlePath,
  getArticleTitle,
  getCategoryLabel,
  getSortedArticles,
} from "../lib/posts";

const articles = await getSortedArticles();
const allCategories = Array.from(
  new Set(articles.map((article) => getArticleCategory(article))),
).sort((a, b) => a.localeCompare(b, "sv"));
const allTags = Array.from(
  new Set(articles.flatMap((article) => article.data.tags)),
).sort((a, b) => a.localeCompare(b, "sv"));
const articleLabel = articles.length === 1 ? "artikel" : "artiklar";
---

<BaseLayout
  title="Anteckningsbiblioteket"
  description="Sökbart anteckningsbibliotek med artiklar i Markdown och MDX."
>
  <section class="hero">
    <p class="eyebrow">Markdown in, publicerad artikel ut</p>
    <h1>Anteckningsbiblioteket</h1>
    <p>
      Spara bra diskussioner som vanliga MDX-filer i GitHub. Varje fil får egen
      URL, blir sökbar och kan filtreras utan databas eller CMS.
    </p>
  </section>

  <section class="controls" aria-label="Sök och filtrera">
    <div class="control-grid">
      <div>
        <label class="search-label" for="search">Sök</label>
        <input
          id="search"
          class="search-input"
          type="search"
          placeholder="Sök i titel, taggar och innehåll"
          autocomplete="off"
        />
      </div>
      <div>
        <label class="search-label" for="category">Kategori</label>
        <select id="category" class="select-input">
          <option value="all">Alla kategorier</option>
          {
            allCategories.map((category) => (
              <option value={category}>{getCategoryLabel(category)}</option>
            ))
          }
        </select>
      </div>
    </div>

    <div class="filter-row" aria-label="Taggfilter">
      <button class="tag-filter is-active" type="button" data-tag="all">
        Alla taggar
      </button>
      {
        allTags.map((tag) => (
          <button class="tag-filter" type="button" data-tag={tag}>
            {tag}
          </button>
        ))
      }
    </div>
  </section>

  <p class="result-count" data-result-count>
    Visar {articles.length} {articleLabel}
  </p>

  <section class="post-list" aria-live="polite">
    {
      articles.map((article) => {
        const path = getArticlePath(article.id);
        const category = getArticleCategory(article);
        const title = getArticleTitle(article);
        const description = getArticleDescription(article);
        const searchable = [
          title,
          description,
          category,
          article.data.tags.join(" "),
          article.body,
        ]
          .join(" ")
          .toLocaleLowerCase("sv-SE");

        return (
          <article
            class="post-card"
            data-post-card
            data-category={category}
            data-tags={article.data.tags.join(",")}
            data-search={searchable}
          >
            <a class="post-card-link" href={`/${path}/`}>
              <div class="card-meta">
                <span>{getCategoryLabel(category)}</span>
                {article.data.date && (
                  <time datetime={article.data.date.toISOString()}>
                    {formatDate(article.data.date)}
                  </time>
                )}
              </div>
              <h2>{title}</h2>
              <p>{description}</p>
            </a>
            <div class="tags" aria-label="Taggar">
              {article.data.tags.map((tag) => (
                <button
                  class="card-tag"
                  type="button"
                  data-card-tag={tag}
                  aria-label={`Filtrera på taggen ${tag}`}
                >
                  {tag}
                </button>
              ))}
            </div>
          </article>
        );
      })
    }
  </section>

  <p class="empty-state" data-empty-state hidden>
    Inga artiklar matchar sökningen eller filtren.
  </p>

  <script>
    const searchInput = document.querySelector("#search");
    const categoryInput = document.querySelector("#category");
    const filterButtons = Array.from(document.querySelectorAll(".tag-filter"));
    const cards = Array.from(document.querySelectorAll("[data-post-card]"));
    const emptyState = document.querySelector("[data-empty-state]");
    const resultCount = document.querySelector("[data-result-count]");
    let activeTag = "all";

    function updateResults() {
      const query = searchInput.value.trim().toLocaleLowerCase("sv-SE");
      const activeCategory = categoryInput.value;
      let visibleCount = 0;

      for (const card of cards) {
        const tags = card.dataset.tags.split(",").filter(Boolean);
        const matchesCategory =
          activeCategory === "all" || card.dataset.category === activeCategory;
        const matchesTag = activeTag === "all" || tags.includes(activeTag);
        const matchesSearch = !query || card.dataset.search.includes(query);
        const isVisible = matchesCategory && matchesTag && matchesSearch;

        card.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      }

      const label = visibleCount === 1 ? "artikel" : "artiklar";
      resultCount.textContent = `Visar ${visibleCount} ${label}`;
      emptyState.hidden = visibleCount !== 0;
    }

    searchInput.addEventListener("input", updateResults);
    categoryInput.addEventListener("change", updateResults);

    for (const button of filterButtons) {
      button.addEventListener("click", () => {
        setActiveTag(button.dataset.tag);
      });
    }

    function setActiveTag(tag) {
      activeTag = tag ?? "all";

      for (const item of filterButtons) {
        item.classList.toggle("is-active", item.dataset.tag === activeTag);
      }

      updateResults();
    }

    function selectCardTag(event) {
      setActiveTag(event.currentTarget.dataset.cardTag);
    }

    for (const tag of document.querySelectorAll("[data-card-tag]")) {
      tag.addEventListener("click", selectCardTag);
    }
  </script>
</BaseLayout>
